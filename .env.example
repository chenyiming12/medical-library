# Reserved for a future permission-protected version.
# Do not put real secrets in frontend-exposed variables.

# Example backend endpoint that could verify a daily key and return a short-lived signed URL.
PRIVATE_PDF_API_ENDPOINT=https://example.com/api/get-pdf-url

# Example private object storage settings for a server-only environment.
# Keep these on the server. Never expose AK/SK or bucket credentials in browser code.
PRIVATE_OBJECT_STORAGE_BUCKET=
PRIVATE_OBJECT_STORAGE_REGION=
PRIVATE_OBJECT_STORAGE_ACCESS_KEY_ID=
PRIVATE_OBJECT_STORAGE_SECRET_ACCESS_KEY=

# Optional daily key salt or verification secret for the future backend.
DAILY_KEY_SECRET=

---
const sections = [
  ['文章基本信息', '题目、作者、期刊、年份、研究对象、模型或样本来源。'],
  ['研究背景', '疾病负担、已知机制、未解决的问题，以及这篇文章进入问题的切入点。'],
  ['研究问题', '用一句话说明作者真正想证明什么，避免只复述实验。'],
  ['技术路线', '按“现象观察 - 机制假设 - 因果验证 - 临床相关性”梳理。'],
  ['结果图解读', '逐图记录实验目的、方法、关键结果、结论和可能的替代解释。'],
  ['机制链总结', '把上游刺激、中间通路、关键分子、下游表型和验证证据串起来。'],
  ['文章亮点', '关注创新点、方法学优势、数据闭环和与临床问题的连接。'],
  ['局限性', '样本量、模型外推、因果验证强度、统计和临床转化不足。'],
];

const qa = [
  [
    'RNA-seq 和 qPCR 都是检测 RNA，为什么结果可能不完全一致？',
    'RNA-seq 更偏全转录组筛查，受测序深度、比对、标准化和批次影响；qPCR 是针对特定基因的验证，受引物设计、内参选择和扩增效率影响。二者趋势一致通常更有说服力，不一致时要回到样本、方法和统计阈值检查。',
  ],
  [
    '为什么机制研究中需要从现象走向因果验证？',
    '单纯相关性只能说明两个变化同时出现，不能说明谁导致谁。机制研究通常需要敲低、过表达、抑制剂、救援实验或动物模型验证，让证据从“看到变化”推进到“改变关键节点会改变结局”。',
  ],
  [
    '如何理解“机制链闭环”？',
    '机制链闭环指研究问题、关键分子、通路变化、表型结果和干预验证彼此能接上：上游为什么变，中间如何传导，下游产生什么表型，反向干预能否救回来。',
  ],
];
---

<section class="report-template">
  <div class="report-intro">
    <h2>医学文献汇报结构</h2>
    <p>
      这个页面提供组会文献汇报的固定骨架，适合把一篇文章拆成研究问题、证据链和可被追问的关键节点。
    </p>
  </div>

  <div class="report-grid">
    {sections.map(([title, body]) => (
      <article>
        <h3>{title}</h3>
        <p>{body}</p>
      </article>
    ))}
  </div>

  <section class="qa-section">
    <h2>老师可能提问 Q&A</h2>
    <div class="qa-list">
      {
        qa.map(([question, answer]) => (
          <details>
            <summary>Q：{question}</summary>
            <p>{answer}</p>
          </details>
        ))
      }
    </div>
  </section>
</section>
